---
import BaseLayout from './BaseLayout.astro';
import ArticleCta from '../components/ArticleCta.astro';
import { getTagHref } from '../lib/blog';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  author: string;
  tags: string[];
  slug: string;
}

const { title, description, date, updated, author, tags, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedDate = updated?.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: {
    '@type': 'Organization',
    name: author,
    url: 'https://researchzero.io/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'ResearchZero',
    url: 'https://researchzero.io/'
  },
  keywords: tags,
  mainEntityOfPage: canonical.href,
  url: canonical.href
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ResearchZero Blog',
      item: new URL(import.meta.env.BASE_URL, Astro.site ?? Astro.url).href
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: canonical.href
    }
  ]
};
---

<BaseLayout
  title={`${title} | ResearchZero`}
  description={description}
  type="article"
  keywords={[...tags, title, slug.replaceAll('-', ' ')]}
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <article class="post-page">
    <header class="post-header">
      <div class="container post-header-inner">
        <div class="article-measure">
          <a class="back-link" href={import.meta.env.BASE_URL}>&larr; All research</a>
          <p class="section-eyebrow">Research Note</p>
          <h1>{title}</h1>
          <p class="post-description">{description}</p>
          <div class="post-meta">
            <span>{formattedDate}</span>
            <span>{author}</span>
            {updatedDate && <span>Updated {updatedDate}</span>}
          </div>
          {tags.length > 0 && (
            <div class="tag-row">
              {tags.map((tag: string) => <a class="tag" href={getTagHref(tag)}>{tag}</a>)}
            </div>
          )}
        </div>
      </div>
    </header>
    <div class="container post-shell">
      <div class="post-content article-measure">
        <slot />
      </div>
      <div class="article-measure">
        <ArticleCta variant="final" />
      </div>
    </div>
  </article>
</BaseLayout>
